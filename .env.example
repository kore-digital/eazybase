DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Lead email notifications (optional — set both on deploy).
# When RESEND_API_KEY is unset, new quote requests are only logged to the server console.
# Get a key at https://resend.com and verify a sending domain to replace the
# onboarding@resend.dev placeholder sender in src/collections/QuoteRequests.ts.
RESEND_API_KEY=
# Recipient for new-lead notifications (defaults to info@eazybase.co.uk).
LEAD_NOTIFY_EMAIL=info@eazybase.co.uk
