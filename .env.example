# ── Database — Supabase Postgres ────────────────────────────────────────────
# Use the CONNECTION POOLER string (Supabase → Project Settings → Database →
# Connection string → "Transaction"/pooler, port 6543). The direct 5432
# connection exhausts under Vercel serverless functions.
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URI=

# Long random string — signs Payload tokens. Generate: openssl rand -hex 32
PAYLOAD_SECRET=

# Public site URL (used for metadata, sitemap, JSON-LD, canonical links).
# Local: http://localhost:3000  •  Prod: https://<your-domain>
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Set to "true" for quick local schema sync (dev only). Leave unset in prod —
# production schema is applied by committed migrations via `payload migrate`.
PAYLOAD_DB_PUSH=

# ── Media storage — Supabase Storage (S3-compatible) ────────────────────────
# Supabase → Storage → create a PUBLIC bucket (e.g. "media").
# S3 creds: Supabase → Project Settings → Storage → S3 access keys.
S3_BUCKET=media
# https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=
# Your Supabase project region, e.g. eu-west-2
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Powers: team lead notifications, customer confirmations, and admin/system
# mail (password resets) — all via the custom Resend HTTP adapter (src/lib/email.ts).
# When RESEND_API_KEY is unset, emails are skipped (logged only).
#   1. Create a free account at https://resend.com
#   2. Add & verify the domain eazybase.co.uk (add the DNS records Resend gives you)
#   3. Create an API key and set it here / in Vercel.
# Sending addresses (from src/lib/email.ts) are leads@ and hello@eazybase.co.uk —
# both covered once eazybase.co.uk is verified.
RESEND_API_KEY=
# Where team lead notifications are sent:
LEAD_NOTIFY_EMAIL=info@eazybase.co.uk

# ── Push notifications (Analytics PWA lead alerts) ──────────────────────────
# Powers new-lead push + the daily "follow-ups due" reminder in the /analytics
# app. Best-effort: when the VAPID keys are unset, push is skipped (logged).
# Generate a keypair once with:  npx web-push generate-vapid-keys
#   - NEXT_PUBLIC_VAPID_PUBLIC_KEY : the PUBLIC key (safe to expose; used by the
#     browser to subscribe). Must be prefixed NEXT_PUBLIC_ to reach the client.
#   - VAPID_PRIVATE_KEY            : the PRIVATE key (secret; server only).
#   - VAPID_SUBJECT (optional)     : a mailto: contact (defaults below).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@eazybase.co.uk

# Protects the daily follow-up cron route (/cron/follow-ups). Vercel Cron sends
# this automatically as `Authorization: Bearer <CRON_SECRET>`. Any long random
# string — generate with: openssl rand -hex 32
CRON_SECRET=
